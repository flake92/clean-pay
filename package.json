{
  "name": "clean-pay",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/next-command.mjs dev",
    "build": "node scripts/next-command.mjs build",
    "start": "next start -H 0.0.0.0 -p 4000",
    "lint": "eslint",
    "test": "node node_modules/vitest/vitest.mjs run --config vitest.config.ts",
    "test:unit": "node node_modules/vitest/vitest.mjs run tests/unit",
    "test:route-handlers": "node node_modules/vitest/vitest.mjs run tests/integration/route-handlers",
    "test:integration": "node node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts --passWithNoTests",
    "test:e2e:devcontainer": "node scripts/e2e-devcontainer.mjs",
    "test:e2e": "node scripts/e2e-devcontainer.mjs",
    "test:coverage": "node node_modules/vitest/vitest.mjs run --coverage",
    "prisma:generate": "node node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node node_modules/prisma/build/index.js migrate dev",
    "prisma:studio": "node node_modules/prisma/build/index.js studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@types/react-transition-group": "^4.4.12",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-transition-group": "^4.4.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "sass": "^1.101.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
