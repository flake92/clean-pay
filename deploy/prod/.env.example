COMPOSE_PROJECT_NAME=clean-pay-prod
CLEAN_PAY_IMAGE=clean-pay-prod-app:local
CLEAN_PAY_BIND=127.0.0.1
CLEAN_PAY_PORT=4000
CLEAN_PAY_EDGE_NETWORK=remnawave-network

POSTGRES_DB=clean_pay
POSTGRES_USER=clean_pay
POSTGRES_PASSWORD=change-me-postgres-password

DATABASE_URL=postgresql://clean_pay:change-me-postgres-password@postgres:5432/clean_pay?schema=public
REDIS_URL=redis://redis:6379/0

APP_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:4000
NEXT_PUBLIC_BRAND_NAME=Clean Pay
NEXT_PUBLIC_BRAND_LOGO_URL=/clean_vpn_logo.jpg
LOG_LEVEL=info

REMNASHOP_API_BASE_URL=https://bot.example.com/api/v1/public
REMNASHOP_DATABASE_URL=postgresql://remnashop:change-me-remnashop-password@remnashop-db:5432/remnashop
REMNAWAVE_API_BASE_URL=https://panel.example.com
REMNAWAVE_TOKEN=change-me

WEB_JWT_SECRET=change-me-long-random-web-jwt-secret
WEB_REFRESH_SECRET=change-me-long-random-web-refresh-secret
AUDIT_IP_HASH_SECRET=change-me-long-random-audit-secret
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

TELEGRAM_OIDC_CLIENT_ID=1234567890
TELEGRAM_OIDC_CLIENT_SECRET=change-me
TELEGRAM_BOT_TOKEN=1234567890:change-me

TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
# For a disposable test stand you may use Cloudflare Turnstile test keys:
# TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

SUPPORT_ENABLED=false
SUPPORT_EMAIL=
SUPPORT_TELEGRAM_USERNAME=
SUPPORT_FAQ_URL=

CLEAN_PAY_READINESS_MAILPIT_URL=
CLEAN_PAY_READINESS_REMNAWAVE_URL=
