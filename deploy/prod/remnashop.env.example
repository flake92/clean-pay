# This file is a checklist for the external Remnashop deployment.
# It is aligned with the current official Remnashop environment documentation.
# Copy values into the real Remnashop .env; Clean Pay does not load this file.

# - - - - - APP CONFIGURATION - - - - - #
APP_DOMAIN=bot.example.com
APP_HOST=0.0.0.0
APP_PORT=5000
APP_LOCALES=ru
APP_DEFAULT_LOCALE=ru
APP_CRYPT_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
APP_ORIGINS=
APP_SWAGGER_ENABLED=false
# Required for Clean Pay: Remnashop only mounts /api/v1/public routes when WEB_ENABLED=true.
WEB_ENABLED=true
WEB_CABINET_URL=https://oplata.example.com/auth/telegram/webapp
# Required by Remnashop when WEB_ENABLED=true. Do not reuse APP_CRYPT_KEY.
APP_API_KEY=change-me-long-random-api-key
APP_JWT_SECRET=change-me-long-random-jwt-secret

# - - - - - EMAIL CONFIGURATION - - - - - #
# Required for Clean Pay email registration flow: Remnashop sends verification codes.
EMAIL_ENABLED=true
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_USERNAME=code@example.com
EMAIL_PASSWORD=change-me-smtp-password
EMAIL_FROM_EMAIL=code@example.com
EMAIL_FROM_NAME=Clean Pay
EMAIL_VERIFICATION_CODE_TTL_MINUTES=15

# - - - - - BOT CONFIGURATION - - - - - #
BOT_TOKEN=1234567890:change-me
BOT_SECRET_TOKEN=change-me-long-random-secret
BOT_OWNER_ID=100000000
BOT_SUPPORT_USERNAME=cleanpay_support
# false = browser, true = WebApp, URL = open that URL as WebApp.
BOT_MINI_APP=https://oplata.example.com/auth/telegram/webapp
BOT_RESET_WEBHOOK=false
BOT_DROP_PENDING_UPDATES=false
BOT_SETUP_COMMANDS=true
BOT_USE_BANNERS=true
BOT_PROXY_URL=

# - - - - - REMNAWAVE CONFIGURATION - - - - - #
# Hostname or Docker service name only. Do not include http://, https://, port, or trailing slash.
REMNAWAVE_HOST=panel.example.com
REMNAWAVE_TOKEN=change-me
# Must match Remnawave WEBHOOK_SECRET_HEADER.
REMNAWAVE_WEBHOOK_SECRET=change-me-long-random-webhook-secret-64-characters
REMNAWAVE_CADDY_TOKEN=
REMNAWAVE_COOKIE=
REMNAWAVE_CF_CLIENT_ID=
REMNAWAVE_CF_CLIENT_SECRET=

# - - - - - DATABASE CONFIGURATION - - - - - #
DATABASE_HOST=remnashop-db
DATABASE_PORT=5432
DATABASE_NAME=remnashop
DATABASE_USER=remnashop
DATABASE_PASSWORD=change-me-postgres-password
DATABASE_ECHO=false
DATABASE_ECHO_POOL=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# - - - - - REDIS CONFIGURATION - - - - - #
REDIS_HOST=remnashop-redis
REDIS_PORT=6379
REDIS_NAME=0
REDIS_PASSWORD=

# - - - - - LOGGING CONFIGURATION - - - - - #
LOG_TO_FILE=true
LOG_LEVEL=DEBUG
LOG_ROTATION=100MB
LOG_COMPRESSION=zip
LOG_RETENTION=3 days
