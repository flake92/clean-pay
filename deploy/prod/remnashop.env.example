# - - - - - APP CONFIGURATION - - - - - #
APP_DOMAIN=bot.example.com
APP_HOST=0.0.0.0
APP_PORT=5000
APP_LOCALES=ru
APP_DEFAULT_LOCALE=ru
APP_CRYPT_KEY=change-me-base64-32-byte-key

# - - - - - BOT CONFIGURATION - - - - - #
BOT_TOKEN=change-me
BOT_SECRET_TOKEN=change-me
BOT_DEV_ID=100000000
BOT_OWNER_ID=100000000
BOT_SUPPORT_USERNAME=support_username
BOT_MINI_APP=https://miniapp.example.com
WEB_ENABLED=true
WEB_CABINET_URL=https://oplata.clear-vpn.org/auth/telegram/webapp
BOT_RESET_WEBHOOK=false
BOT_DROP_PENDING_UPDATES=false
BOT_SETUP_COMMANDS=true
BOT_USE_BANNERS=true
BOT_INLINE_MODE=true

# - - - - - REMNAWAVE CONFIGURATION - - - - - #
REMNAWAVE_HOST=panel.example.com
REMNAWAVE_PORT=3000
REMNAWAVE_TOKEN=change-me
REMNAWAVE_WEBHOOK_SECRET=change-me
REMNAWAVE_CADDY_TOKEN=
REMNAWAVE_COOKIE=

# - - - - - DATABASE CONFIGURATION - - - - - #
DATABASE_HOST=remnashop-db
DATABASE_PORT=5432
DATABASE_NAME=remnashop
DATABASE_USER=remnashop
DATABASE_PASSWORD=change-me
DATABASE_ECHO=false
DATABASE_ECHO_POOL=false
DATABASE_POOL_SIZE=30
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=10
DATABASE_POOL_RECYCLE=3600

# - - - - - REDIS CONFIGURATION - - - - - #
REDIS_HOST=remnashop-redis
REDIS_PORT=6379
REDIS_NAME=0
REDIS_PASSWORD=change-me

# - - - - - EMAIL / SMTP CONFIGURATION - - - - - #
# Configure these on the real external Remnashop server. Clean Pay calls
# /auth/email/request-verification, and Remnashop returns 503 when email
# delivery is not configured.
EMAIL_ENABLED=true
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_USERNAME=change-me
EMAIL_PASSWORD=change-me
EMAIL_FROM_EMAIL=no-reply@example.com
EMAIL_FROM_NAME=Clean Pay
EMAIL_VERIFICATION_CODE_TTL_MINUTES=15

# Compatibility aliases for Remnashop builds that read SMTP_* or MAIL_* names.
SMTP_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USERNAME=change-me
SMTP_PASSWORD=change-me
SMTP_USER=change-me
SMTP_PASS=change-me
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Clean Pay

MAIL_ENABLED=true
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_TLS=true
MAIL_SSL=false
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=change-me
MAIL_PASSWORD=change-me
MAIL_USER=change-me
MAIL_PASS=change-me
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_FROM_NAME=Clean Pay
