generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuditSeverity {
  INFO
  WARN
  ERROR
}

enum IntegrationStatusKind {
  UNKNOWN
  OK
  DEGRADED
  DOWN
}

model WebUser {
  id                      String                   @id @default(cuid())
  remnashopUserId         String?                  @unique
  email                   String?                  @unique
  telegramId              BigInt?                  @unique
  telegramUsername        String?
  fullName                String?
  photoUrl                String?
  lastLoginAt             DateTime?
  emailVerified           Boolean                  @default(false)
  displayName             String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  sessions                WebSession[]
  auditLogs               AuditLog[]
  emailVerificationCodes  EmailVerificationCode[]
  telegramAuthStates      TelegramAuthState[]

  @@index([email])
  @@index([telegramId])
}

model TelegramAuthState {
  id                 String    @id @default(cuid())
  stateHash          String    @unique
  nonceHash          String    @unique
  codeVerifierHash   String    @unique
  redirectTo         String?
  userId             String?
  expiresAt          DateTime
  consumedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               WebUser?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([expiresAt])
  @@index([consumedAt])
  @@index([userId])
}

model WebSession {
  id                   String    @id @default(cuid())
  userId               String
  refreshTokenHash     String    @unique
  userAgent            String?
  ipHash               String?
  accessTokenExpiresAt DateTime
  refreshExpiresAt     DateTime
  revokedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 WebUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accessTokenExpiresAt])
  @@index([refreshExpiresAt])
  @@index([revokedAt])
}

model EmailVerificationCode {
  id           String    @id @default(cuid())
  userId       String
  codeHash     String
  attempts     Int       @default(0)
  maxAttempts  Int       @default(5)
  sentAt       DateTime  @default(now())
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         WebUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([sentAt])
  @@index([consumedAt])
}

model AuditLog {
  id          String        @id @default(cuid())
  userId      String?
  action      String
  severity    AuditSeverity @default(INFO)
  ipHash      String?
  metadata    Json?
  createdAt   DateTime      @default(now())
  user        WebUser?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model RateLimitEvent {
  id          String   @id @default(cuid())
  key         String
  action      String
  occurredAt  DateTime @default(now())
  metadata    Json?

  @@index([key, action, occurredAt])
}

model AppSetting {
  key        String   @id
  value      Json
  updatedAt  DateTime @updatedAt
}

model IntegrationStatus {
  id          String                @id @default(cuid())
  service     String                @unique
  status      IntegrationStatusKind @default(UNKNOWN)
  message     String?
  checkedAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}
