# Только параметры инфраструктурного prestage. Секреты будущего приложения
# определяются по software-spec/02-interfaces/configuration.md.
COMPOSE_PROJECT_NAME=clean-pay-dev

# Существующие тома сохранены после старой dev-среды.
CLEAN_PAY_POSTGRES_VOLUME=clean-pay-dev_postgres-data
CLEAN_PAY_REDIS_VOLUME=clean-pay-dev_redis-data
REMNASHOP_POSTGRES_VOLUME=clean-pay-dev_remnashop-postgres-data
REMNASHOP_CACHE_VOLUME=clean-pay-dev_remnashop-cache-data
REMNASHOP_ASSETS_VOLUME=clean-pay-dev_remnashop-assets
REMNASHOP_LOGS_VOLUME=clean-pay-dev_remnashop-logs
CADDY_DATA_VOLUME=clean-pay-dev_caddy-data
CADDY_CONFIG_VOLUME=clean-pay-dev_caddy-config

POSTGRES_DB=clean_pay
POSTGRES_USER=clean_pay
POSTGRES_PASSWORD=clean_pay
POSTGRES_PORT=5432
REDIS_PORT=6379
REMNASHOP_PORT=5001
REMNASHOP_POSTGRES_PORT=6767
REMNAWAVE_MOCK_PORT=3001
TELEGRAM_MOCK_PORT=8082
TELEGRAM_OIDC_MOCK_PORT=8090
MAILPIT_HTTP_PORT=8025
MAILPIT_SMTP_PORT=1025

# Профиль edge: адрес Ruby-приложения относительно контейнера Caddy.
APP_UPSTREAM=host.docker.internal:4000
CADDY_APP_PORT=8080
CADDY_REMNASHOP_PORT=8081
CADDY_MAILPIT_PORT=8026
CLEAN_PAY_WEBAPP_URL=https://clean-pay.localhost/auth/telegram/webapp
CLEAN_PAY_PRESTAGE_NETWORK=clean-pay-prestage
