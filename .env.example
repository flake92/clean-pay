# Rails application: safe local/prestage values, never production secrets.
APP_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:4000
NEXT_PUBLIC_BRAND_NAME=Clean Pay
NEXT_PUBLIC_BRAND_LOGO_URL=/clean-pay-logo.png
DATABASE_URL=postgresql://clean_pay:clean_pay@127.0.0.1:5432/clean_pay
TEST_DATABASE_URL=postgresql://clean_pay:clean_pay@127.0.0.1:5432/clean_pay_test
REDIS_URL=redis://127.0.0.1:6379/0
REMNASHOP_API_BASE_URL=http://127.0.0.1:5001/api/v1/public
REMNASHOP_ADMIN_API_BASE_URL=http://127.0.0.1:5001/api/v1/admin
REMNASHOP_API_KEY=dev-remnashop-api-key-change-me
REMNAWAVE_API_BASE_URL=http://127.0.0.1:3001
REMNAWAVE_TOKEN=dev-remnawave-token-not-production
WEB_JWT_SECRET=dev-jwt-secret-32-characters-minimum
WEB_REFRESH_SECRET=dev-refresh-secret-32-characters-minimum
AUDIT_IP_HASH_SECRET=dev-audit-ip-secret-32-characters-minimum
RATE_LIMIT_IDENTITY_SECRET=dev-rate-limit-secret-32-characters-minimum
READINESS_INTERNAL_SECRET=dev-readiness-secret-32-characters-minimum
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
TELEGRAM_OIDC_CLIENT_ID=dev-telegram-client-id
TELEGRAM_OIDC_CLIENT_SECRET=dev-telegram-client-secret
TELEGRAM_BOT_TOKEN=0000000000:dev-telegram-bot-token-placeholder
TELEGRAM_OIDC_ISSUER=http://localhost:8090
TELEGRAM_OIDC_AUTHORIZATION_ENDPOINT=http://localhost:8090/auth
TELEGRAM_OIDC_TOKEN_ENDPOINT=http://127.0.0.1:8090/token
TELEGRAM_OIDC_JWKS_URI=http://127.0.0.1:8090/.well-known/jwks.json
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
SUPPORT_ENABLED=false
SUPPORT_EMAIL=
SUPPORT_TELEGRAM_USERNAME=
SUPPORT_FAQ_URL=
PAYMENT_RECONCILIATION_ENABLED=true
PAYMENT_RECONCILIATION_SECRET=dev-reconciliation-secret-32-characters
PAYMENT_RECONCILIATION_BATCH_SIZE=10
PAYMENT_RECONCILIATION_INTERVAL_SECONDS=30
PAYMENT_RECONCILIATION_INTERNAL_URL=http://app:4000/internal/payment_reconciliations
CLEAN_PAY_READINESS_MAILPIT_URL=http://smtp:8025
CLEAN_PAY_READINESS_REMNAWAVE_URL=http://remnawave-mock:3000
AUTH_STATE_RETENTION_DAYS=7
SESSION_RETENTION_DAYS=90
AUDIT_INFO_RETENTION_DAYS=180
AUDIT_SECURITY_RETENTION_DAYS=365
RATE_LIMIT_RETENTION_DAYS=30
DATA_RETENTION_INTERVAL_SECONDS=21600
CLEAN_PAY_BIND=0.0.0.0
CLEAN_PAY_PORT=4000
RUN_MIGRATIONS=true
LOG_LEVEL=info
CLEAN_PAY_BUILD_ID=local-prestage
RAILS_ENV=development

# External prestage infrastructure.
COMPOSE_PROJECT_NAME=clean-pay-dev
CLEAN_PAY_IMAGE=clean-pay:prestage
CLEAN_PAY_ENV_FILE=.env.example
CLEAN_PAY_EDGE_NETWORK=clean-pay-prestage

# Существующие тома сохранены после старой dev-среды.
CLEAN_PAY_POSTGRES_VOLUME=clean-pay-dev_postgres-data
CLEAN_PAY_REDIS_VOLUME=clean-pay-dev_redis-data
REMNASHOP_POSTGRES_VOLUME=clean-pay-dev_remnashop-postgres-data
REMNASHOP_CACHE_VOLUME=clean-pay-dev_remnashop-cache-data
REMNASHOP_ASSETS_VOLUME=clean-pay-dev_remnashop-assets
REMNASHOP_LOGS_VOLUME=clean-pay-dev_remnashop-logs
CADDY_DATA_VOLUME=clean-pay-dev_caddy-data
CADDY_CONFIG_VOLUME=clean-pay-dev_caddy-config

POSTGRES_DB=clean_pay
POSTGRES_USER=clean_pay
POSTGRES_PASSWORD=clean_pay
POSTGRES_PORT=5432
REDIS_PORT=6379
REMNASHOP_PORT=5001
REMNASHOP_POSTGRES_PORT=6767
REMNAWAVE_MOCK_PORT=3001
TELEGRAM_MOCK_PORT=8082
TELEGRAM_OIDC_MOCK_PORT=8090
MAILPIT_HTTP_PORT=8025
MAILPIT_SMTP_PORT=1025

# Профиль edge: адрес Ruby-приложения относительно контейнера Caddy.
APP_UPSTREAM=host.docker.internal:4000
CADDY_APP_PORT=8080
CADDY_REMNASHOP_PORT=8081
CADDY_MAILPIT_PORT=8026
CLEAN_PAY_WEBAPP_URL=https://clean-pay.localhost/auth/telegram/webapp
CLEAN_PAY_PRESTAGE_NETWORK=clean-pay-prestage
