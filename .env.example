COMPOSE_PROJECT_NAME=clean-pay
CLEAN_PAY_IMAGE=clean-pay:local
CLEAN_PAY_BIND=127.0.0.1
CLEAN_PAY_PORT=4000
REMNASHOP_DOCKER_NETWORK=remnawave-network

POSTGRES_DB=clean_pay
POSTGRES_USER=clean_pay
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL="postgresql://clean_pay:change-me-postgres-password@postgres:5432/clean_pay?schema=public"

APP_URL="https://app.example.com"
NEXT_PUBLIC_APP_URL="https://app.example.com"
NEXT_PUBLIC_BRAND_NAME="Clean Pay"
NEXT_PUBLIC_BRAND_LOGO_URL="/clean-pay-logo.png"
LOG_LEVEL="info"

REMNASHOP_API_BASE_URL="https://remnashop.example.com/api/v1/public"
REMNASHOP_API_KEY="change-me-remnashop-app-api-key"
REMNAWAVE_API_BASE_URL="https://panel.example.com"
REMNAWAVE_TOKEN="change-me"

REDIS_URL="redis://redis:6379/0"

WEB_JWT_SECRET="change-me"
WEB_REFRESH_SECRET="change-me"
AUDIT_IP_HASH_SECRET="change-me"
COOKIE_SECURE="true"
COOKIE_SAMESITE="lax"

TELEGRAM_OIDC_CLIENT_ID="change-me"
TELEGRAM_OIDC_CLIENT_SECRET="change-me"
TELEGRAM_BOT_TOKEN=""

SUPPORT_ENABLED="false"
SUPPORT_EMAIL=""
SUPPORT_TELEGRAM_USERNAME=""
SUPPORT_FAQ_URL=""

# Optional dependencies included in /api/health/readiness.
CLEAN_PAY_READINESS_MAILPIT_URL=""
CLEAN_PAY_READINESS_REMNAWAVE_URL=""

# Cloudflare Turnstile. Do not commit real secret values.
TURNSTILE_ENABLED="false"
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
TURNSTILE_VERIFY_URL="https://challenges.cloudflare.com/turnstile/v0/siteverify"
