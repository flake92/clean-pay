{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Clean Pay: prepare",
      "type": "shell",
      "command": "npm install && npm run prisma:generate",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Clean Pay: migrate",
      "type": "shell",
      "dependsOn": "Clean Pay: prepare",
      "command": "npm run prisma:migrate",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Clean Pay: build",
      "type": "shell",
      "dependsOn": "Clean Pay: prepare",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Clean Pay: test unit",
      "type": "npm",
      "script": "test:unit",
      "group": "test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Clean Pay: test route handlers",
      "type": "npm",
      "script": "test:route-handlers",
      "group": "test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Clean Pay: test integration",
      "type": "npm",
      "script": "test:integration",
      "group": "test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
