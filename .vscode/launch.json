{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Clean Pay: Dev Normal (3000)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "Clean Pay: install dependencies",
      "command": "npm run dev -- --hostname 0.0.0.0",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "http://localhost:3000",
        "action": "openExternally"
      }
    },
    {
      "name": "Clean Pay: Dev Mock (3001)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "Clean Pay: install dependencies",
      "command": "npm run dev:mock -- --hostname 0.0.0.0",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "http://localhost:3001",
        "action": "openExternally"
      }
    },
    {
      "name": "Clean Pay: Start Normal (3000)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "Clean Pay: install dependencies",
      "command": "npm run build && npm run start:normal -- --hostname 0.0.0.0",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "http://localhost:3000",
        "action": "openExternally"
      }
    },
    {
      "name": "Clean Pay: Start Mock (3001)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "Clean Pay: install dependencies",
      "command": "npm run build && npm run start:mock -- --hostname 0.0.0.0",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "http://localhost:3001",
        "action": "openExternally"
      }
    },
    {
      "name": "Clean Pay: Prisma Studio",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "Clean Pay: install dependencies",
      "command": "npm run prisma:studio -- --hostname 0.0.0.0",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Prisma Studio is up on (https?://\\S+)",
        "uriFormat": "http://localhost:5555",
        "action": "openExternally"
      }
    },
    {
      "name": "Clean Pay: Start Normal + Mock (3000/3001)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "Clean Pay: install dependencies",
      "command": "npm run build && (npm run start:normal -- --hostname 0.0.0.0 & npm run start:mock -- --hostname 0.0.0.0)",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "http://localhost:3000",
        "action": "openExternally"
      }
    }
  ]
}
