{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Clean Pay: Dev Normal (4000)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "Clean Pay: install dependencies",
      "command": "npm run dev -- --hostname 0.0.0.0",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Local:\\s+http://localhost:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Clean Pay: Dev Mock (4001)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "Clean Pay: install dependencies",
      "command": "npm run dev:mock -- --hostname 0.0.0.0",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Local:\\s+http://localhost:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Clean Pay: Start Normal (4000)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "Clean Pay: install dependencies",
      "command": "npm run build && npm run start:normal",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Local:\\s+http://localhost:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Clean Pay: Start Mock (4001)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "Clean Pay: install dependencies",
      "command": "npm run build:mock && npm run start:mock",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Local:\\s+http://localhost:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Clean Pay: Prisma Studio",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "Clean Pay: install dependencies",
      "command": "npm run prisma:studio -- --hostname 0.0.0.0",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Prisma Studio is up on http://localhost:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Clean Pay: Start Normal + Mock (4000/4001)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "Clean Pay: install dependencies",
      "command": "npm run build && npm run build:mock && (npm run start:normal & npm run start:mock)",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Local:\\s+http://localhost:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    }
  ]
}
