{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Clean Pay: Dev Normal (4000)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "Clean Pay: install dependencies",
      "command": "npm run dev -- --hostname 0.0.0.0",
      "cwd": "${workspaceFolder}",
      "env": {
        "DATABASE_URL": "postgresql://postgres:postgres@db:5432/postgres?schema=public",
        "APP_URL": "http://localhost:4000",
        "NEXT_PUBLIC_APP_URL": "http://localhost:4000",
        "REMNASHOP_API_BASE_URL": "http://remnashop-mock:8080/api/v1/public",
        "REDIS_URL": "redis://redis:6379/0",
        "WEB_JWT_SECRET": "dev-web-jwt-secret-change-me",
        "WEB_REFRESH_SECRET": "dev-web-refresh-secret-change-me",
        "AUDIT_IP_HASH_SECRET": "dev-audit-ip-hash-secret-change-me",
        "COOKIE_SECURE": "false",
        "COOKIE_SAMESITE": "lax",
        "SMTP_HOST": "mailpit",
        "SMTP_PORT": "1025",
        "SMTP_USER": "clean-pay",
        "SMTP_PASSWORD": "dev-smtp-password-change-me",
        "SMTP_FROM": "CleanVPN <clean-pay@example.com>",
        "TELEGRAM_OIDC_ISSUER": "https://oauth.telegram.org",
        "TELEGRAM_OIDC_AUTHORIZATION_ENDPOINT": "https://oauth.telegram.org/auth",
        "TELEGRAM_OIDC_TOKEN_ENDPOINT": "https://oauth.telegram.org/token",
        "TELEGRAM_OIDC_JWKS_URI": "https://oauth.telegram.org/.well-known/jwks.json",
        "TELEGRAM_OIDC_CLIENT_ID": "dev-telegram-client-id",
        "TELEGRAM_OIDC_CLIENT_SECRET": "dev-telegram-client-secret",
        "TURNSTILE_ENABLED": "true",
        "NEXT_PUBLIC_TURNSTILE_SITE_KEY": "1x00000000000000000000AA",
        "TURNSTILE_SECRET_KEY": "1x0000000000000000000000000000000AA",
        "TURNSTILE_VERIFY_URL": "http://turnstile-mock:8787/turnstile/v0/siteverify",
        "SUPPORT_ENABLED": "false",
        "SUPPORT_EMAIL": "",
        "SUPPORT_TELEGRAM_USERNAME": "",
        "SUPPORT_FAQ_URL": "",
        "CLEAN_PAY_MOCK_MODE": "0"
      },
      "serverReadyAction": {
        "pattern": "Local:\\s+http://localhost:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
