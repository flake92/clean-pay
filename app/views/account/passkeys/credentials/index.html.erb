<section aria-labelledby="passkeys-title">
  <h1 id="passkeys-title">Ключи доступа</h1>

  <% if @credentials.any? %>
    <ul>
      <% @credentials.each do |credential| %>
        <li>
          <span><%= credential.name.presence || "Ключ доступа" %></span>
          <time datetime="<%= credential.created_at.iso8601 %>">
            <%= l credential.created_at, format: :short %>
          </time>
          <%= button_to "Удалить",
                account_passkey_path(credential),
                method: :delete,
                disabled: @credentials.one?,
                aria: {
                  label: "Удалить #{credential.name.presence || 'ключ доступа'}"
                } %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p>Ключи доступа пока не настроены.</p>
  <% end %>
</section>
