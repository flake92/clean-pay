<% content_for :title, "Подтверждение регистрации — Clean Pay" %>
<section class="auth-content">
  <header class="auth-heading">
    <h1>Подтверждение e-mail</h1>
    <p>Введите 6 цифр из письма, чтобы завершить регистрацию.</p>
  </header>
  <%= form_with scope: :email_verification,
    url: account_email_verification_path, method: :patch,
    class: "form-stack", data: { controller: "form-lock" } do |form| %>
    <%= form.hidden_field :registration_flow, value: true %>
    <%= form.label :code, "Код подтверждения" %>
    <%= form.text_field :code, required: true, inputmode: "numeric",
      autocomplete: "one-time-code", pattern: "[0-9]{6}", minlength: 6,
      maxlength: 6, placeholder: "000000" %>
    <%= render "shared/turnstile" %>
    <%= form.submit "Подтвердить e-mail", class: "button button--full",
      data: { form_lock_target: "submit" } %>
  <% end %>
  <%= form_with scope: :email_verification,
    url: account_email_verification_path,
    data: { controller: "form-lock" } do |form| %>
    <%= form.hidden_field :email, value: Current.web_user&.email %>
    <%= render "shared/turnstile" %>
    <%= form.submit "Отправить код повторно",
      class: "button button--outline button--full",
      data: { form_lock_target: "submit" } %>
  <% end %>
  <%= button_to "Назад", account_session_path, method: :delete,
    class: "button button--outline button--full" %>
</section>
